# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=SmartData AI Platform
APP_VERSION=1.0.0
DEBUG=false

# ── JWT ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DB=smartdata

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=smartdata_nosql

# ── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ── ML ─────────────────────────────────────────────────────────────────────────
MODEL_PATH=backend/app/ml/model.pkl
